# --- Supabase (audit log + case storage) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Orchestrator ---
# The origin the orchestrator calls agent routes on. Locally: http://localhost:3000
APP_BASE_URL=

# --- Per-agent API keys ---
# Each agent CAN use its own key (own spend cap, own rate limit, own audit trail
# on Anthropic's side). If you don't need that separation yet, set only the
# fallback ANTHROPIC_API_KEY and leave the rest blank — each agent falls back to it.
ANTHROPIC_API_KEY=

ANTHROPIC_API_KEY_SPINOZA=
ANTHROPIC_API_KEY_KROPOTKIN=
ANTHROPIC_API_KEY_WEIL=
ANTHROPIC_API_KEY_SOLZHENITSYN=
ANTHROPIC_API_KEY_IBNRUSHD=
ANTHROPIC_API_KEY_GRAMSCI=
ANTHROPIC_API_KEY_GANDHI=
ANTHROPIC_API_KEY_DIOGENES=
ANTHROPIC_API_KEY_BOETHIUS=
ANTHROPIC_API_KEY_LUXEMBURG=
ANTHROPIC_API_KEY_LABOETIE=
ANTHROPIC_API_KEY_AGGREGATOR=
