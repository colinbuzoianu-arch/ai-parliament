# --- Supabase (audit log + case storage) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Orchestrator ---
# The origin the orchestrator calls agent routes on. Locally: http://localhost:3000
APP_BASE_URL=

# --- Admin ---
# Shared secret for /api/admin/approve-case — sent as the x-admin-secret header.
ADMIN_SECRET=

# --- Per-agent API keys ---
# Each agent CAN use its own key (own spend cap, own rate limit, own audit trail
# on OpenAI's side). If you don't need that separation yet, set only the
# fallback OPENAI_API_KEY and leave the rest blank — each agent falls back to it.
OPENAI_API_KEY=

OPENAI_API_KEY_SPINOZA=
OPENAI_API_KEY_KROPOTKIN=
OPENAI_API_KEY_WEIL=
OPENAI_API_KEY_SOLZHENITSYN=
OPENAI_API_KEY_IBNRUSHD=
OPENAI_API_KEY_GRAMSCI=
OPENAI_API_KEY_GANDHI=
OPENAI_API_KEY_DIOGENES=
OPENAI_API_KEY_BOETHIUS=
OPENAI_API_KEY_LUXEMBURG=
OPENAI_API_KEY_LABOETIE=
OPENAI_API_KEY_AGGREGATOR=
